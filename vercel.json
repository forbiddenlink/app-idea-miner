{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb"
            }
        },
        {
            "src": "apps/web/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "api/index.py" },
        { "src": "/health", "dest": "api/index.py" },
        { "src": "/metrics", "dest": "api/index.py" },
        { "src": "/docs/(.*)", "dest": "api/index.py" },
        { "src": "/docs", "dest": "api/index.py" },
        { "src": "/redoc", "dest": "api/index.py" },
        { "src": "/openapi.json", "dest": "api/index.py" },
        { "src": "/assets/(.*)", "dest": "apps/web/assets/$1" },
        { "src": "/(vite\\.svg|favicon\\.ico|robots\\.txt)", "dest": "apps/web/$1" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "apps/web/index.html" }
    ]
}
